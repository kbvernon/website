@misc{vernon-etal-2025a,
	address = {Salt Lake City, UT},
	type = {Talk},
	title = {Indirect dating with {Mixture} {Density} {Networks}},
	shorttitle = {Utah {Center} for {Data} {Science}, {Data} {Science} \& {AI} {Lecture} {Series}},
	url = {pdfs/pp-dss2025-mdn.pdf},
	abstract = {The two most powerful forces driving long-term development in human societies are climate change and demography, so it should come as no surprise that so much archaeological research is focused on developing new methods for estimating key climate and demographic quantities in the past. To aid in these efforts, specifically demographic reconstruction, this project proposes a new spatio-temporal deep learning (DL) framework indirect dating. The core of this new framework is a Mixture Density Network (MDN) trained on multi-site archaeological tree-ring date and ceramic assemblage data. We also show how to handle mis-aligned data using spatially-weighted feature aggregation and spatial basis functions. Training and testing data are provided by cyberSW, including an extremely large ceramic assemblage dataset covering much of the US Southwest.},
	author = {Vernon, Kenneth B. and Codding, Brian F and Ortman, Scott G. and Brewer, Simon C.},
	year = {2025},
}

